[include]
	path = ~/.config/git/common.gitconfig

[user]
	name = Chris Birch
	email = datapointchris@gmail.com

[core]
	editor = nvim
	pager = delta
	autocrlf = input
	excludesfile = /home/chris/.config/git/ignore

# The empty helper = clears any inherited/system helpers before setting ours,
# preventing git from stacking multiple helpers and causing unexpected prompts.
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential

[includeIf "gitdir:~/code/"]
	path = ~/code/.gitconfig
