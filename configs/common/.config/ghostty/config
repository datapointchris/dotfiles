# Theme colors (imported)
config-file = themes/current.conf

# Font settings (imported - use 'font apply' to change)
config-file = fonts/current.conf

# Opacity (imported - use 'theme opacity-up/down' to change)
config-file = opacity/current.conf

macos-titlebar-style = hidden

# Linux/GTK chrome — match Ghostty's palette, use the terminal font for tab
# labels, flatten the toolbar, and let tabs size to their content.
window-theme = ghostty
window-title-font-family = "Comic Mono Nerd Font 13"
gtk-toolbar-style = flat
gtk-wide-tabs = true
gtk-custom-css = themes/current.css
gtk-custom-css = fonts/current.css

window-padding-x = 16
window-padding-y = 0,4
window-padding-balance = false

# Font rendering preferences
font-style = Regular
adjust-cell-height = 3
adjust-cell-width = 0
font-thicken = false
font-feature = -liga
font-feature = -calt
font-feature = -clig

keybind = shift+enter=text:\x1b\r
