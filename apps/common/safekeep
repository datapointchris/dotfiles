#!/usr/bin/env python3
"""safekeep - Config-driven file preservation with dated snapshots and retention.

Rsync-copies files and directories to a destination with dated snapshots and
automatic retention pruning. Primary use case: backing up scattered config files,
local scripts, and git-untracked WIP to a network drive for crash protection.

Config: ~/.config/safekeep/<name>.json
Usage: safekeep [--config NAME] [--dry-run] [--init [NAME]] [--show-config]
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime
from fnmatch import fnmatch
from pathlib import Path

# ANSI color helpers — no dependencies needed, every modern terminal supports these
def _color(code, text):
    return f"\033[{code}m{text}\033[0m"

def cyan(text): return _color("36", text)
def green(text): return _color("32", text)
def yellow(text): return _color("33", text)
def red(text): return _color("31", text)
def bold(text): return _color("1", text)


VALID_KEYS = {"dest", "keep", "exclude", "paths", "git_untracked", "git_ignored"}

DEFAULT_EXCLUDES = [
    ".venv", "node_modules", "__pycache__", ".mypy_cache", ".ruff_cache",
    ".pytest_cache", "build", "dist", "*.pyc", ".DS_Store",
]

CONFIG_DIR = Path.home() / ".config" / "safekeep"

EXAMPLE_CONFIG = {
    "dest": "~/backups/safekeep",
    "keep": 7,
    "paths": [
        "~/.ssh/config",
        "~/.gnupg/pubring.kbx",
        "~/Documents/notes",
    ],
    "git_untracked": [
        "~/code/my-project",
    ],
}

CONFIG_FORMAT_HELP = """\
config format:
  Files live in ~/.config/safekeep/<name>.json

  required keys:
    dest              Backup destination directory (~ is expanded)
    keep              Number of dated snapshots to retain

  optional keys:
    exclude           List of glob patterns to skip (sensible defaults if omitted)
    paths             List of absolute paths to back up (~ is expanded)
    git_untracked     List of absolute paths to git repos -- copies their untracked files
    git_ignored       List of glob patterns to capture from git_untracked repos
                      (e.g. ["CLAUDE.md", ".planning"] to back up gitignored files)

  destination structure:
    dest/YYYY-MM-DD/  A dated subdirectory is created for each day's backup.
                      Full directory structure is preserved from filesystem root.
    Dated directories beyond the 'keep' count are pruned automatically.

  examples:
    safekeep --init                Create starter config (~/.config/safekeep/default.json)
    safekeep --init work           Create starter config (~/.config/safekeep/work.json)
    safekeep --show-config         Display the resolved config and exit"""


def resolve_config(name):
    """Resolve config by name, absolute path, or auto-detect single config."""
    if name:
        path = Path(name)
        if path.is_absolute() and path.exists():
            return path
        config_path = CONFIG_DIR / f"{name}.json"
        if config_path.exists():
            return config_path
        print(f"{red('safekeep:')} config not found: {yellow(name)}", file=sys.stderr)
        print(f"  looked in: {cyan(str(config_path))}", file=sys.stderr)
        print(f"  generate it: {cyan(f'safekeep --init {name}')}", file=sys.stderr)
        sys.exit(1)

    # Auto-detect: list configs in CONFIG_DIR
    if not CONFIG_DIR.exists():
        print(f"{red('safekeep:')} no config directory at {cyan(str(CONFIG_DIR))}", file=sys.stderr)
        print(f"  generate a starter config: {cyan('safekeep --init')}", file=sys.stderr)
        sys.exit(1)

    configs = sorted(CONFIG_DIR.glob("*.json"))
    if not configs:
        print(f"{red('safekeep:')} no configs found in {cyan(str(CONFIG_DIR))}", file=sys.stderr)
        print(f"  generate a starter config: {cyan('safekeep --init')}", file=sys.stderr)
        sys.exit(1)
    if len(configs) == 1:
        return configs[0]

    print(f"{yellow('safekeep:')} multiple configs found, specify one with {cyan('--config')}:", file=sys.stderr)
    for c in configs:
        print(f"  {green(c.stem)}", file=sys.stderr)
    sys.exit(1)


def load_config(config_path):
    """Load and validate config file."""
    with open(config_path) as f:
        config = json.load(f)

    for key in ("dest", "keep"):
        if key not in config:
            print(f"{red('safekeep:')} config missing required key {yellow(repr(key))}: {cyan(str(config_path))}", file=sys.stderr)
            sys.exit(1)

    unknown = set(config.keys()) - VALID_KEYS
    if unknown:
        print(f"{red('safekeep:')} unknown config keys: {yellow(', '.join(sorted(unknown)))}", file=sys.stderr)
        print(f"  valid keys: {cyan(', '.join(sorted(VALID_KEYS)))}", file=sys.stderr)
        sys.exit(1)

    return config


def git_ls_untracked(repo_path):
    """Get list of untracked files from a git repository."""
    try:
        result = subprocess.run(
            ["git", "ls-files", "--others", "--exclude-standard"],
            cwd=repo_path,
            capture_output=True,
            text=True,
            check=True,
        )
        return [repo_path / line for line in result.stdout.strip().splitlines() if line]
    except (subprocess.CalledProcessError, FileNotFoundError):
        print(f"  {yellow('warning:')} could not list untracked files in {cyan(str(repo_path))}")
        return []


def git_ls_ignored(repo_path, patterns):
    """Get list of gitignored files matching patterns from a git repository.

    Uses git ls-files --others (without --exclude-standard) and subtracts the
    --exclude-standard set to get only ignored files, then filters to those
    matching the given glob patterns.
    """
    try:
        all_result = subprocess.run(
            ["git", "ls-files", "--others"],
            cwd=repo_path,
            capture_output=True,
            text=True,
            check=True,
        )
        untracked_result = subprocess.run(
            ["git", "ls-files", "--others", "--exclude-standard"],
            cwd=repo_path,
            capture_output=True,
            text=True,
            check=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        print(f"  {yellow('warning:')} could not list ignored files in {cyan(str(repo_path))}")
        return []

    all_files = set(all_result.stdout.strip().splitlines())
    untracked_files = set(untracked_result.stdout.strip().splitlines())
    ignored_files = all_files - untracked_files

    matched = []
    for rel_path in sorted(ignored_files):
        if not rel_path:
            continue
        for pattern in patterns:
            if fnmatch(rel_path, pattern) or any(fnmatch(part, pattern) for part in Path(rel_path).parts):
                matched.append(repo_path / rel_path)
                break

    return matched


def matches_exclude(rel_path, excludes):
    """Check if any path component matches an exclude pattern."""
    for part in Path(rel_path).parts:
        for pattern in excludes:
            if fnmatch(part, pattern):
                return True
    return False


def rsync_paths(paths, dest_base, excludes, dry_run=False):
    """Rsync absolute paths into dest_base, preserving full directory structure.

    Uses rsync --relative with absolute paths so that '/home/chris/.ssh/config'
    becomes dest_base/home/chris/.ssh/config.
    """
    valid = []
    for p in paths:
        expanded = Path(p).expanduser()
        if expanded.exists():
            valid.append(str(expanded))
        else:
            print(f"  {yellow('skip:')} {expanded} {yellow('(not found)')}")

    if not valid:
        return 0

    if not dry_run:
        dest_base.mkdir(parents=True, exist_ok=True)

    cmd = ["rsync", "-av", "--no-perms", "--chmod=Du+w", "--relative", "--copy-links"]
    for pattern in excludes:
        cmd.extend(["--exclude", pattern])
    if dry_run:
        cmd.append("-n")
    cmd.extend(valid)
    cmd.append(str(dest_base) + "/")

    subprocess.run(cmd, check=True)
    return len(valid)


def rsync_untracked(files, dest_base, dry_run=False):
    """Rsync individual untracked files preserving full path structure.

    Uses --files-from with / as the base for efficiency when copying many
    small files. Paths are stored relative to filesystem root in the destination.
    """
    rel_paths = [str(f).lstrip("/") for f in files]

    if not rel_paths:
        return 0

    if not dry_run:
        dest_base.mkdir(parents=True, exist_ok=True)

    with tempfile.NamedTemporaryFile(mode="w", suffix=".txt", delete=False) as tmp:
        tmp.write("\n".join(rel_paths) + "\n")
        tmp_path = tmp.name

    try:
        cmd = ["rsync", "-av", "--no-perms", "--files-from", tmp_path, "/", str(dest_base) + "/"]
        if dry_run:
            cmd.append("-n")
        subprocess.run(cmd, check=True)
    finally:
        os.unlink(tmp_path)

    return len(rel_paths)



def prune_old_backups(dest, keep):
    """Remove dated backup directories beyond the keep count."""
    dated = sorted(
        [d for d in dest.iterdir()
         if d.is_dir() and not d.is_symlink()
         and len(d.name) == 10 and d.name[4] == "-" and d.name[7] == "-"],
        reverse=True,
    )
    removed = dated[keep:]
    for d in removed:
        shutil.rmtree(d)
    return removed


def init_config(name):
    """Generate an example config file."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    config_path = CONFIG_DIR / f"{name}.json"

    if config_path.exists():
        print(f"{yellow('safekeep:')} config already exists: {cyan(str(config_path))}", file=sys.stderr)
        print(f"  use {cyan('--show-config')} to view it, or edit directly", file=sys.stderr)
        sys.exit(1)

    config_path.write_text(json.dumps(EXAMPLE_CONFIG, indent=2) + "\n")

    print(f"{green('safekeep:')} created {cyan(str(config_path))}")
    print()
    print(f"  Edit the file to match your backup needs, then preview with:")
    print(f"    {cyan(f'safekeep --config {name} --dry-run')}")
    print()
    print(f"  Config format reference:")
    print(f"    {cyan('safekeep --help')}")


def show_config(config_path, config):
    """Display the resolved config with readable formatting."""
    print(f"{bold('safekeep:')} {cyan(str(config_path))}")
    print()
    print(f"  {bold('dest:')}    {cyan(config['dest'])}")
    print(f"  {bold('keep:')}    {config['keep']} snapshots")
    excludes = config.get("exclude", DEFAULT_EXCLUDES)
    print(f"  {bold('exclude:')} {', '.join(excludes)}")

    paths = config.get("paths", [])
    repos = config.get("git_untracked", [])

    if paths:
        print(f"\n  {bold('paths')} ({len(paths)}):")
        for p in paths:
            print(f"    {p}")

    if repos:
        print(f"\n  {bold('git_untracked')} ({len(repos)}):")
        for r in repos:
            print(f"    {r}")

    ignored_patterns = config.get("git_ignored", [])
    if ignored_patterns:
        print(f"\n  {bold('git_ignored')} patterns: {', '.join(ignored_patterns)}")
        print(f"    applied to {len(repos)} git_untracked repos")

    if not paths and not repos:
        print(f"\n  {yellow('no paths or git_untracked defined')}")


def main():
    parser = argparse.ArgumentParser(
        prog="safekeep",
        description="Config-driven file preservation with dated snapshots and retention",
        epilog=CONFIG_FORMAT_HELP,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "-c", "--config",
        help="Config name or absolute path (default: auto-detect)",
    )
    parser.add_argument(
        "-n", "--dry-run",
        action="store_true",
        help="Show what would be copied without doing it",
    )
    parser.add_argument(
        "--init",
        nargs="?",
        const="default",
        metavar="NAME",
        help="Generate starter config (default name: 'default')",
    )
    parser.add_argument(
        "--show-config",
        action="store_true",
        help="Display the resolved config and exit",
    )
    args = parser.parse_args()

    if args.init is not None:
        name = args.config or args.init
        init_config(name)
        sys.exit(0)

    # Resolve and load config
    config_path = resolve_config(args.config)
    config = load_config(config_path)

    if args.show_config:
        show_config(config_path, config)
        sys.exit(0)

    print(f"{bold('safekeep:')} using config {cyan(config_path.name)}", flush=True)

    dest = Path(config["dest"]).expanduser()
    keep = config["keep"]
    excludes = config.get("exclude", DEFAULT_EXCLUDES)

    # Create destination if it doesn't exist, fail if parent is unreachable
    try:
        dest.mkdir(parents=True, exist_ok=True)
    except OSError as e:
        print(f"{red('safekeep:')} cannot create destination {yellow(str(dest))} — {e}", file=sys.stderr)
        sys.exit(1)
    if not os.access(dest, os.W_OK):
        print(f"{red('safekeep:')} destination {yellow(str(dest))} is not writable", file=sys.stderr)
        sys.exit(1)

    date_dir = datetime.now().strftime("%Y-%m-%d")
    dest_base = dest / date_dir
    total = 0

    # Static paths
    paths = config.get("paths", [])
    if paths:
        print(f"\n{bold('paths:')}")
        count = rsync_paths(paths, dest_base, excludes, args.dry_run)
        label = yellow("would copy") if args.dry_run else green("copied")
        print(f"  {label} {bold(str(count))} paths")
        total += count

    # Git untracked
    repos = config.get("git_untracked", [])
    if repos:
        print(f"\n{bold('git_untracked:')}")
        for repo in repos:
            repo_path = Path(repo).expanduser()
            if not repo_path.exists():
                print(f"  {yellow('skip:')} {yellow(str(repo_path))} (not found)")
                continue
            untracked = git_ls_untracked(repo_path)
            filtered = [f for f in untracked if not matches_exclude(str(f), excludes)]
            count = rsync_untracked(filtered, dest_base, args.dry_run)
            label = yellow("would copy") if args.dry_run else green("copied")
            print(f"  {label} {bold(str(count))} untracked files from {cyan(str(repo_path))}")
            total += count

    # Git ignored files matching patterns
    ignored_patterns = config.get("git_ignored", [])
    if ignored_patterns and repos:
        print(f"\n{bold('git_ignored:')}")
        for repo in repos:
            repo_path = Path(repo).expanduser()
            if not repo_path.exists():
                continue
            ignored = git_ls_ignored(repo_path, ignored_patterns)
            filtered = [f for f in ignored if not matches_exclude(str(f), excludes)]
            if not filtered:
                continue
            count = rsync_untracked(filtered, dest_base, args.dry_run)
            label = yellow("would copy") if args.dry_run else green("copied")
            print(f"  {label} {bold(str(count))} ignored files from {cyan(str(repo_path))}")
            total += count

    if not args.dry_run:
        # Prune old backups
        removed = prune_old_backups(dest, keep)
        if removed:
            print(f"{yellow('pruned')} {bold(str(len(removed)))} old backups: {', '.join(d.name for d in removed)}")

    label = yellow("would back up") if args.dry_run else green("backed up")
    print(f"\n{bold('safekeep:')} {label} {bold(str(total))} items to {cyan(str(dest / date_dir))}")


if __name__ == "__main__":
    main()
