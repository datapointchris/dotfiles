#!/usr/bin/env python3
"""Cycle through toolbox registry tools, reminding about forgotten ones.
Skips tools used within the last 90 days (uses EXTENDED_HISTORY timestamps).
Uses yq to convert registry YAML → JSON, then stdlib only.
"""

import json
import os
import re
import subprocess
import sys
import time
from datetime import date
from pathlib import Path

REGISTRY = Path(os.environ.get("DOTFILES_REGISTRY", Path.home() / ".config/toolbox/registry.yml"))
HISTORY = Path(os.environ.get("HISTFILE", Path.home() / ".local/state/zsh/history"))
STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "toolbox"
REMINDERS_FILE = STATE_DIR / "reminders.json"
CUTOFF_DAYS = 90

YELLOW = "\033[0;33m"
CYAN = "\033[0;36m"
RESET = "\033[0m"


def load_registry() -> dict:
    result = subprocess.run(
        ["yq", "-r", ".", str(REGISTRY)],
        capture_output=True, text=True
    )
    return json.loads(result.stdout).get("tools", {})


def recently_used_tools(cutoff_ts: float) -> set:
    used = set()
    if not HISTORY.exists():
        return used
    pattern = re.compile(r"^: (\d+):\d+;(\S+)")
    for line in HISTORY.read_bytes().splitlines():
        text = line.decode("utf-8", errors="replace")
        m = pattern.match(text)
        if m and float(m.group(1)) > cutoff_ts:
            used.add(m.group(2))
    return used


def load_reminders() -> dict:
    if REMINDERS_FILE.exists():
        return json.loads(REMINDERS_FILE.read_text())
    return {}


def save_reminder(tool: str) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    reminders = load_reminders()
    reminders[tool] = date.today().isoformat()
    REMINDERS_FILE.write_text(json.dumps(reminders, indent=2))


def pick_tool(tools: dict, recently_used: set, reminders: dict):
    """Return (name, description) for the tool reminded least recently, or None."""
    best_name = None
    best_date = "9999-99-99"
    for name, info in tools.items():
        if name in recently_used:
            continue
        last = reminders.get(name, "0000-00-00")
        if last < best_date:
            best_date = last
            best_name = name
    if best_name is None:
        return None
    desc = tools[best_name].get("description") or "(no description)"
    return best_name, desc


def main() -> None:
    tools = load_registry()
    cutoff_ts = time.time() - CUTOFF_DAYS * 86400
    recently_used = recently_used_tools(cutoff_ts)
    reminders = load_reminders()

    result = pick_tool(tools, recently_used, reminders)
    if result is None:
        return

    name, desc = result
    print(f"\n  {YELLOW}reminder{RESET} — {CYAN}{name}{RESET}")
    print(f"  {desc}\n")

    save_reminder(name)


if __name__ == "__main__":
    main()
