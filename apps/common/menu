#!/usr/bin/env bash
# menu - List personal CLI tools with descriptions from the toolbox registry

set -euo pipefail

SHELL_DIR="${SHELL_DIR:-$HOME/.local/shell}"
source "$SHELL_DIR/formatting.sh"

REGISTRY="${DOTFILES_REGISTRY:-$HOME/.config/toolbox/registry.yml}"

lookup_desc() {
  local name="$1"
  local desc
  desc=$(yq ".tools[\"$name\"].description" "$REGISTRY" 2>/dev/null)
  [[ "$desc" == "null" || -z "$desc" ]] && echo "" || echo "$desc"
}

print_entry() {
  local name="$1"
  local desc
  desc=$(lookup_desc "$name")
  if [[ -n "$desc" ]]; then
    echo "  $(print_cyan "$name") — $desc"
  else
    echo "  $(print_cyan "$name") $(print_yellow "(not in registry)")"
  fi
}

print_header "Personal Tools" "brightcyan"
echo ""

print_section "$HOME/tools" "brightyellow"
for dir in "$HOME"/tools/*/; do
  [[ -d "$dir" ]] || continue
  print_entry "$(basename "$dir")"
done

echo ""
print_section "dotfiles scripts" "brightyellow"
for file in "$HOME"/dotfiles/apps/common/*; do
  [[ -f "$file" ]] || continue
  print_entry "$(basename "$file")"
done
echo ""
