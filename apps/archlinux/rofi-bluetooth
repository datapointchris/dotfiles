#!/usr/bin/env bash
# rofi-bluetooth - Manage bluetooth devices via rofi

set -euo pipefail

get_device_info() {
    bluetoothctl info "$1" 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g'
}

is_connected() {
    echo "$1" | grep -q "Connected: yes"
}

is_paired() {
    echo "$1" | grep -q "Paired: yes"
}

get_battery() {
    local battery
    battery=$(echo "$1" | grep "Battery Percentage" | grep -oP '\(\K[0-9]+(?=\))') || true
    echo "${battery:-}"
}

build_device_menu() {
    local show_new="$1"
    local devices
    devices=$(bluetoothctl devices 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g' | grep -E '^Device [A-F0-9:]{17} ') || true

    MENU_MACS=()
    MENU_DISPLAYS=()
    MENU_TEXT=""

    while read -r _ mac name; do
        [[ -z "$mac" ]] && continue

        local info
        info=$(get_device_info "$mac")

        if ! is_paired "$info"; then
            [[ "$show_new" != "true" ]] && continue
        fi

        if [[ -z "$name" || "$name" == "$mac" ]]; then
            name=$(echo "$info" | grep "Name:" | sed 's/.*Name: //' | xargs)
            [[ -z "$name" ]] && name="$mac"
        fi

        MENU_MACS+=("$mac")

        local status_icon="" battery_str="" suffix=""

        if is_connected "$info"; then
            status_icon="тЧП"
        elif is_paired "$info"; then
            status_icon="тЧЛ"
        else
            status_icon="тЧЗ"
            suffix=" [new]"
        fi

        local battery
        battery=$(get_battery "$info")
        if [[ -n "$battery" ]]; then
            battery_str=" ($battery%)"
        fi

        local display="$status_icon $name$battery_str$suffix"
        MENU_DISPLAYS+=("$display")
        MENU_TEXT+="$display\n"
    done <<< "$devices"
}

do_pair_connect() {
    local mac="$1"
    local name="$2"

    notify-send -t 3000 "Bluetooth" "Pairing $name..." 2>/dev/null || true

    # Keep a persistent bluetoothctl session so the device stays discoverable
    coproc PAIR_BT { bluetoothctl 2>&1; }
    local pair_pid="${PAIR_BT_PID}"

    # Scan to keep device visible, trust before pairing
    echo "scan on" >&"${PAIR_BT[1]}"
    sleep 2
    echo "trust $mac" >&"${PAIR_BT[1]}"
    sleep 1
    echo "pair $mac" >&"${PAIR_BT[1]}"
    sleep 5
    echo "connect $mac" >&"${PAIR_BT[1]}"
    sleep 3

    # Read result
    echo "scan off" >&"${PAIR_BT[1]}"
    echo "quit" >&"${PAIR_BT[1]}"
    local output
    output=$(cat <&"${PAIR_BT[0]}" | sed 's/\x1b\[[0-9;]*m//g') || true
    wait "$pair_pid" 2>/dev/null || true

    if echo "$output" | grep -q "Pairing successful\|already exists"; then
        notify-send -t 3000 "Bluetooth" "Connected to $name" 2>/dev/null || true
    else
        notify-send -t 5000 "Bluetooth" "Failed to pair $name тАФ try again" 2>/dev/null || true
    fi
}

do_connect() {
    local mac="$1"
    local name="$2"
    bluetoothctl connect "$mac" >/dev/null 2>&1
    notify-send -t 3000 "Bluetooth" "Connected to $name" 2>/dev/null || true
}

do_disconnect() {
    local mac="$1"
    local name="$2"
    bluetoothctl disconnect "$mac" >/dev/null 2>&1
    notify-send -t 3000 "Bluetooth" "Disconnected $name" 2>/dev/null || true
}

do_remove() {
    local mac="$1"
    local name="$2"
    bluetoothctl disconnect "$mac" >/dev/null 2>&1
    bluetoothctl remove "$mac" >/dev/null 2>&1
    notify-send -t 3000 "Bluetooth" "Removed $name" 2>/dev/null || true
}

show_device_menu() {
    local mac="$1"
    local info
    info=$(get_device_info "$mac")
    local name
    name=$(echo "$info" | grep "Name:" | sed 's/.*Name: //' | xargs)
    [[ -z "$name" ]] && name="$mac"

    local battery
    battery=$(get_battery "$info")
    local battery_line=""
    [[ -n "$battery" ]] && battery_line="Battery: ${battery}%  |  "

    local menu=""
    if is_connected "$info"; then
        menu="тПП Disconnect\nтЬХ Disconnect & Remove"
    elif is_paired "$info"; then
        menu="тПО Connect\nтЬХ Remove"
    else
        menu="тПО Pair & Connect\nтЬХ Remove"
    fi

    local header="${battery_line}${mac}"
    local choice
    choice=$(printf '%b' "тЖР Back\n${menu}" | \
        rofi -dmenu -i -p "$name" -no-custom \
        -mesg "$header" \
        2>/dev/null) || return

    case "$choice" in
        "тЖР Back") show_main_menu ;;
        "тПО Connect") do_connect "$mac" "$name" ;;
        "тПО Pair & Connect") do_pair_connect "$mac" "$name" ;;
        "тПП Disconnect") do_disconnect "$mac" "$name" ;;
        "тЬХ Disconnect & Remove") do_remove "$mac" "$name" ;;
        "тЬХ Remove") do_remove "$mac" "$name" ;;
    esac
}

scan_and_select() {
    # Start scanning via a persistent bluetoothctl process
    coproc BTCTL { bluetoothctl 2>&1; }
    echo "scan on" >&"${BTCTL[1]}"

    trap '{ echo "scan off" >&"${BTCTL[1]}"; echo "quit" >&"${BTCTL[1]}"; } 2>/dev/null || true; wait "${BTCTL_PID}" 2>/dev/null' EXIT

    local choice=""
    local rounds=0
    local max_rounds=4

    while [[ -z "$choice" && $rounds -lt $max_rounds ]]; do
        rounds=$((rounds + 1))
        sleep 2

        build_device_menu "true"

        local header="Scanning... (${rounds}/${max_rounds}) - Select device or wait"
        if [[ $rounds -ge $max_rounds ]]; then
            header="Scan complete - Select device"
        fi

        choice=$(printf '%b' "тЖ╗ Refresh\n${MENU_TEXT}" | \
            rofi -dmenu -i -p "Bluetooth" -no-custom \
            -mesg "$header" \
            2>/dev/null) || return

        if [[ "$choice" == "тЖ╗ Refresh" ]]; then
            choice=""
            continue
        fi
    done

    [[ -z "$choice" ]] && return

    # Stop the scan session before handing off to device menu
    echo "scan off" >&"${BTCTL[1]}" || true
    echo "quit" >&"${BTCTL[1]}" || true
    wait "${BTCTL_PID}" 2>/dev/null || true
    trap - EXIT

    for i in "${!MENU_DISPLAYS[@]}"; do
        if [[ "${MENU_DISPLAYS[$i]}" == "$choice" ]]; then
            show_device_menu "${MENU_MACS[$i]}"
            return
        fi
    done
}

show_main_menu() {
    build_device_menu "false"

    local menu="тЯ│ Scan for devices\n${MENU_TEXT}"

    local choice
    choice=$(printf '%b' "$menu" | rofi -dmenu -i -p "Bluetooth" -no-custom) || exit 0

    if [[ "$choice" == "тЯ│ Scan for devices" ]]; then
        scan_and_select
        exit 0
    fi

    for i in "${!MENU_DISPLAYS[@]}"; do
        if [[ "${MENU_DISPLAYS[$i]}" == "$choice" ]]; then
            show_device_menu "${MENU_MACS[$i]}"
            exit 0
        fi
    done
}

# Global arrays for menu building
declare -a MENU_MACS=() MENU_DISPLAYS=()
MENU_TEXT=""

show_main_menu
